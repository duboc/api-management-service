# === API Gateway Manager Configuration ===
# Copy to .env and fill in values. Or run: ./scripts/setup.sh

# GCP Project
GCP_PROJECT_ID=mestrealvaro
GCP_REGION=us-central1

# App Server
HOST=0.0.0.0
PORT=8081
LOG_LEVEL=INFO

# API Gateway
# Set after creating an API via the web UI
GATEWAY_API_ID=
GATEWAY_REGION=us-central1

# Cloud Run Proxy
PROXY_SERVICE_NAME=vertex-ai-proxy
PROXY_SERVICE_ACCOUNT=

# Vertex AI - Custom Endpoints (deployed models)
# Set the numeric endpoint ID if using a custom deployed model
VERTEX_AI_ENDPOINT_ID=
VERTEX_AI_REGION=us-central1

# Vertex AI - Generative AI (Gemini publisher models)
# Examples: gemini-2.5-flash, gemini-2.5-pro, gemini-2.5-flash
VERTEX_AI_MODEL=gemini-2.5-flash
